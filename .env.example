# App
PORT=3000
ORIGIN=https://yourdomain.com

# Auth / Security
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING_64_CHARS

# Email (use app password, keep secret)
GMAIL_USERNAME=your_email@gmail.com
GMAIL_PASSWORD=REPLACE_WITH_APP_PASSWORD

# Appwrite (treat as secret)
APPWRITE_KEY=REPLACE_WITH_SECRET_KEY
APPWRITE_PROJECT_ID=66fcf1c90026f557bda2
APPWRITE_BUCKET_ID=66fcf20a002f09d9b7ab

# Mongo (DO NOT use admin/password)
MONGO_INITDB_ROOT_USERNAME=devlabs_root
MONGO_INITDB_ROOT_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# IMPORTANT: use service name "mongo", not 127.0.0.1
MONGODB_URI=mongodb://devlabs_root:REPLACE_WITH_STRONG_PASSWORD@mongo:27017/DevLabs?authSource=admin

# Connection Pool
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_SIZE=2
DB_MAX_IDLE_TIME_MS=30000
DB_CONNECT_TIMEOUT=10000
DB_SOCKET_TIMEOUT=45000
DB_HEARTBEAT_FREQUENCY=10000
DB_SERVER_SELECTION_TIMEOUT=30000

# MinIO (strong credentials)
MINIO_ACCESS_KEY=devlabs_minio
MINIO_SECRET_KEY=REPLACE_WITH_LONG_RANDOM_PASSWORD

# Internal connection (use container name)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false

# Public access (through reverse proxy ideally)
MINIO_PUBLIC_URL=https://storage.yourdomain.com

MINIO_BUCKET=devlabs

# mongo-express (optional, avoid in production)
ME_CONFIG_BASICAUTH_USERNAME=admin_ui
ME_CONFIG_BASICAUTH_PASSWORD=REPLACE_WITH_STRONG_PASSWORD